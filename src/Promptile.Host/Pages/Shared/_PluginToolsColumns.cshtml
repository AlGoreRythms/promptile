@model Promptile.Host.Pages.PluginsModel.PluginInfo

<div class="plugin-tools-columns">
    <!-- Left column: MCP Tools -->
    @if (Model.McpTools.Any())
    {
        <div class="plugin-tools-column">
            <div class="plugin-tools-header">
                <h3>MCP Tools <span class="text-muted">@Model.McpTools.Count(t => t.Enabled)/@Model.McpTools.Count</span></h3>
                <div class="plugin-tools-actions">
                    <button hx-post="/Plugins?handler=EnableAllTools&pluginId=@Model.Plugin.Id"
                            hx-target="#tools-columns-@Model.Plugin.Id" hx-swap="innerHTML"
                            class="toggle-btn-sm toggle-on">All On</button>
                    <button hx-post="/Plugins?handler=DisableAllTools&pluginId=@Model.Plugin.Id"
                            hx-target="#tools-columns-@Model.Plugin.Id" hx-swap="innerHTML"
                            class="toggle-btn-sm toggle-off">All Off</button>
                </div>
            </div>
            <p class="text-sm text-muted">Tools exposed to external MCP clients</p>
            <div class="plugin-tools-scroll-wrap">
                <div class="plugin-tools-scroll">
                    @foreach (var tool in Model.McpTools)
                    {
                        <div class="tool-row @(!tool.Enabled ? "tool-row-disabled" : "")">
                            <button hx-post="/Plugins?handler=ToggleTool&pluginId=@Model.Plugin.Id&toolName=@tool.Name"
                                    hx-target="#tools-columns-@Model.Plugin.Id" hx-swap="innerHTML"
                                    class="toggle-btn-sm @(tool.Enabled ? "toggle-on" : "toggle-off")">
                                @(tool.Enabled ? "On" : "Off")
                            </button>
                            <div class="tool-row-info">
                                <code class="tool-row-name">@tool.Name</code>
                                <span class="text-sm text-muted">@tool.Description</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Right column: Tool Access -->
    @if (Model.AccessibleTools.Any())
    {
        <div class="plugin-tools-column">
            <div class="plugin-tools-header">
                <h3>Tool Access <span class="text-muted">@Model.AccessibleTools.Count(t => t.Allowed)/@Model.AccessibleTools.Count</span></h3>
                <div class="plugin-tools-actions">
                    <button hx-post="/Plugins?handler=EnableAllAccess&pluginId=@Model.Plugin.Id"
                            hx-target="#tools-columns-@Model.Plugin.Id" hx-swap="innerHTML"
                            class="toggle-btn-sm toggle-on">All On</button>
                    <button hx-post="/Plugins?handler=DisableAllAccess&pluginId=@Model.Plugin.Id"
                            hx-target="#tools-columns-@Model.Plugin.Id" hx-swap="innerHTML"
                            class="toggle-btn-sm toggle-off">All Off</button>
                </div>
            </div>
            <p class="text-sm text-muted">Tools available when @Model.Plugin.DisplayName calls Claude</p>
            <div class="plugin-tools-scroll-wrap">
                <div class="plugin-tools-scroll">
                    @foreach (var group in Model.AccessibleTools.GroupBy(t => t.PluginName))
                    {
                        <div class="tool-group-label">@group.Key</div>
                        @foreach (var tool in group)
                        {
                            <div class="tool-row @(!tool.Allowed ? "tool-row-disabled" : "")">
                                <button hx-post="/Plugins?handler=ToggleAccess&pluginId=@Model.Plugin.Id&toolName=@tool.ToolName"
                                        hx-target="#tools-columns-@Model.Plugin.Id" hx-swap="innerHTML"
                                        class="toggle-btn-sm @(tool.Allowed ? "toggle-on" : "toggle-off")">
                                    @(tool.Allowed ? "On" : "Off")
                                </button>
                                <div class="tool-row-info">
                                    <code class="tool-row-name">@tool.ToolName</code>
                                    <span class="text-sm text-muted">@tool.Description</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

<script>
    // Re-init scroll fade after HTMX swap
    document.querySelectorAll('#tools-columns-@Model.Plugin.Id .plugin-tools-scroll').forEach(function(el) {
        var wrap = el.closest('.plugin-tools-scroll-wrap');
        if (!wrap) return;
        function check() {
            var atBottom = el.scrollHeight - el.scrollTop - el.clientHeight < 4;
            var noScroll = el.scrollHeight <= el.clientHeight;
            wrap.classList.toggle('scrolled-bottom', atBottom || noScroll);
        }
        el.addEventListener('scroll', check);
        check();
    });
</script>
