@page
@model Assistant.Host.Pages.DataSourcesModel
@{
    ViewData["Title"] = "Data Sources";
    var editingConfig = Model.EditingId != null
        ? Model.Configs.FirstOrDefault(c => c.Id == Model.EditingId)
        : null;
}

<div class="flex justify-between items-center mb-3">
    <h1 style="margin:0">Data Sources</h1>
    @if (!Model.ShowAdd && Model.EditingId == null)
    {
        <div class="flex gap-1">
            @if (Model.Configs.Any(c => c.Enabled))
            {
                <form method="post" asp-page-handler="ResetAll">
                    <button class="secondary"
                            onclick="return confirm('Reset sync state for all sources and re-fetch from the beginning?')">
                        ↺ Resync All
                    </button>
                </form>
            }
            <a href="/DataSources?add=true" class="btn">+ Add Source</a>
        </div>
    }
</div>

@if (Model.ShowAdd || Model.EditingId != null)
{
    var editing = editingConfig;
    var selectedType = editing?.Type ?? Request.Query["type"].ToString();
    if (string.IsNullOrEmpty(selectedType)) selectedType = Model.Providers.FirstOrDefault()?.Type ?? "";
    var provider = Model.Providers.FirstOrDefault(p => p.Type == selectedType);
    var isOAuth = provider?.GetAuthStartUrl("_") != null;
    var isNewOAuthSource = isOAuth && editing == null;
    var oauthDone = editing != null && editing.Config.ContainsKey("refreshToken");

    <div class="card mb-3" style="border-color: var(--accent)">
        <h2>@(editing != null ? "Edit Data Source" : "Add Data Source")</h2>

        <form method="post" asp-page-handler="Save">
            <input type="hidden" name="id" value="@(editing?.Id ?? "")" />

            <div class="mb-3">
                <label class="text-sm text-muted">Name <span class="text-muted">(used to group related sources)</span></label>
                <input type="text" name="name" value="@(editing?.Name ?? "")"
                       placeholder="e.g. Work, Personal, Home" required />
            </div>

            <div class="mb-3">
                <label class="text-sm text-muted">Type</label>
                @if (editing != null)
                {
                    <input type="hidden" name="type" value="@editing.Type" />
                    <div class="flex items-center gap-1">
                        <span class="plugin-card-icon" style="width:28px;height:28px;font-size:1rem">@provider?.Icon</span>
                        <strong>@provider?.DisplayName</strong>
                    </div>
                }
                else
                {
                    <input type="hidden" name="type" value="@selectedType" />
                    <select id="type-select" style="width:auto"
                            onchange="window.location='/DataSources?add=true&type='+encodeURIComponent(this.value)">
                        @foreach (var p in Model.Providers)
                        {
                            if (p.Type == selectedType)
                            {
                                <option value="@p.Type" selected>@p.Icon @p.DisplayName</option>
                            }
                            else
                            {
                                <option value="@p.Type">@p.Icon @p.DisplayName</option>
                            }
                        }
                    </select>
                }
            </div>

            @if (provider != null)
            {
                @if (isNewOAuthSource)
                {
                    @* New OAuth source: show credential fields then redirect to provider auth *@
                    <div style="border-top:1px solid var(--border); padding-top:1rem; margin-top:0.5rem">
                        <div class="text-sm text-muted mb-2" style="font-weight:600; text-transform:uppercase; letter-spacing:.04em">
                            @provider.DisplayName Credentials
                        </div>
                        @foreach (var field in provider.GetPreAuthFields())
                        {
                            var fval = "";
                            <div class="mb-3">
                                <label class="text-sm text-muted">
                                    @field.Label
                                    @if (field.Required) { <span style="color:var(--danger)">*</span> }
                                </label>
                                @if (field.FieldType == "password")
                                {
                                    <input type="password" name="@field.Key" value="@fval"
                                           placeholder="@field.Placeholder" autocomplete="new-password"
                                           style="font-family:monospace" />
                                }
                                else
                                {
                                    <input type="text" name="@field.Key" value="@fval"
                                           placeholder="@field.Placeholder" />
                                }
                                @if (!string.IsNullOrEmpty(field.Help))
                                {
                                    <div class="text-sm text-muted mt-1">@field.Help</div>
                                }
                            </div>
                        }
                        <div class="text-sm text-muted mb-3" style="background:var(--surface-2,#f5f5f5); padding:0.75rem; border-radius:6px">
                            After saving, you'll be redirected to @provider.DisplayName to authorize access.
                        </div>
                    </div>
                    <div class="flex gap-1 mt-2">
                        <button type="submit">Save &amp; Authorize →</button>
                        <a href="/DataSources" class="btn secondary">Cancel</a>
                    </div>
                }
                else
                {
                    @* Existing source or non-OAuth: show config fields *@
                    @if (oauthDone)
                    {
                        <div class="text-sm mb-3" style="color:var(--success)">✓ Authorized with @provider.DisplayName</div>
                    }
                    <div style="border-top:1px solid var(--border); padding-top:1rem; margin-top:0.5rem">
                        <div class="text-sm text-muted mb-2" style="font-weight:600; text-transform:uppercase; letter-spacing:.04em">
                            @provider.DisplayName Configuration
                        </div>
                        @foreach (var field in provider.GetConfigFields())
                        {
                            var fval = editing?.Config.TryGetValue(field.Key, out var fcv) == true ? fcv : "";
                            <div class="mb-3">
                                <label class="text-sm text-muted">
                                    @field.Label
                                    @if (field.Required) { <span style="color:var(--danger)">*</span> }
                                </label>
                                @if (field.FieldType == "password")
                                {
                                    <input type="password" name="@field.Key" value="@fval"
                                           placeholder="@field.Placeholder" autocomplete="new-password"
                                           style="font-family:monospace" />
                                }
                                else if (field.FieldType == "textarea")
                                {
                                    <textarea name="@field.Key" placeholder="@field.Placeholder">@fval</textarea>
                                }
                                else if (field.FieldType == "select" && field.Options != null)
                                {
                                    <select name="@field.Key" style="width:auto">
                                        @foreach (var opt in field.Options)
                                        {
                                            var optLabel = opt switch {
                                                "all" => "All messages",
                                                "unread" => "Unread only",
                                                "mentions" => "Mentions & DMs only",
                                                "dms" => "DMs only",
                                                _ => opt
                                            };
                                            if (opt == fval)
                                            {
                                                <option value="@opt" selected>@optLabel</option>
                                            }
                                            else
                                            {
                                                <option value="@opt">@optLabel</option>
                                            }
                                        }
                                    </select>
                                }
                                else
                                {
                                    <input type="text" name="@field.Key" value="@fval"
                                           placeholder="@field.Placeholder" />
                                }
                                @if (!string.IsNullOrEmpty(field.Help))
                                {
                                    <div class="text-sm text-muted mt-1">@field.Help</div>
                                }
                            </div>
                        }
                    </div>
                    <div class="flex gap-1 mt-2">
                        <button type="submit">@(editing != null ? "Save Changes" : "Add Source")</button>
                        <a href="/DataSources" class="btn secondary">Cancel</a>
                    </div>
                }
            }
            else
            {
                <div class="flex gap-1 mt-2">
                    <button type="submit">Add Source</button>
                    <a href="/DataSources" class="btn secondary">Cancel</a>
                </div>
            }
        </form>
    </div>
}

@if (!Model.Configs.Any())
{
    <div class="card" style="text-align:center; padding:3rem">
        <h2>No data sources configured</h2>
        <p class="text-muted mt-1">
            Connect Slack, Gmail, Obsidian, and more to give the Assistant visibility into your world.
        </p>
        @if (!Model.ShowAdd)
        {
            <div class="mt-2"><a href="/DataSources?add=true" class="btn">+ Add your first source</a></div>
        }
    </div>
}
else
{
    @foreach (var cfg in Model.Configs)
    {
        var cfgProvider = Model.Providers.FirstOrDefault(p => p.Type == cfg.Type);
        Model.Statuses.TryGetValue(cfg.Id, out var status);
        var isRunning = status != null;

        <div class="card mb-2 @(!cfg.Enabled ? "plugin-disabled" : "")">
            <div class="plugin-card-header">
                <span class="plugin-card-icon" style="font-size:1.2rem">
                    @(cfgProvider?.Icon ?? "📦")
                </span>
                <div>
                    <div style="display:flex; align-items:center; gap:0.5rem">
                        <strong style="font-size:1rem">@cfg.Name</strong>
                        <span class="badge">@(cfgProvider?.DisplayName ?? cfg.Type)</span>
                    </div>
                    @if (isRunning && status != null)
                    {
                        <div class="text-sm text-muted mt-1">
                            @if (status.Connected)
                            {
                                <span style="color:var(--success)">● Connected</span>
                                if (!string.IsNullOrEmpty(status.Message))
                                {
                                    <span class="text-muted"> — @status.Message</span>
                                }
                            }
                            else
                            {
                                <span style="color:var(--danger)">● @(status.Message ?? "Error")</span>
                            }
                        </div>
                    }
                    else if (!cfg.Enabled)
                    {
                        <div class="text-sm text-muted mt-1">Disabled</div>
                    }
                    else
                    {
                        <div class="text-sm text-muted mt-1">Starting…</div>
                    }
                </div>

                <div style="margin-left:auto; display:flex; align-items:center; gap:0.5rem">
                    @if (status?.AuthUrl != null)
                    {
                        <a href="@status.AuthUrl" class="btn" style="font-size:0.8rem; padding:0.3rem 0.7rem">🔑 Re-authorize</a>
                    }
                    <a href="/DataSources?edit=@cfg.Id" class="btn secondary" style="font-size:0.8rem; padding:0.3rem 0.7rem">Edit</a>

                    @if (cfg.Enabled)
                    {
                        <form method="post" asp-page-handler="ResetSync"
                              onsubmit="return confirm('Reset sync state and re-fetch from the beginning?')" style="margin:0">
                            <input type="hidden" name="id" value="@cfg.Id" />
                            <button type="submit" class="secondary" style="font-size:0.8rem; padding:0.3rem 0.7rem" title="Clear sync state and re-fetch all data">↺ Re-sync</button>
                        </form>
                    }

                    <form method="post" asp-page-handler="Toggle" style="margin:0">
                        <input type="hidden" name="id" value="@cfg.Id" />
                        <button type="submit" class="toggle-btn @(cfg.Enabled ? "toggle-on" : "toggle-off")">
                            @(cfg.Enabled ? "Enabled" : "Disabled")
                        </button>
                    </form>

                    <form method="post" asp-page-handler="Delete"
                          onsubmit="return confirm('Delete @cfg.Name?')" style="margin:0">
                        <input type="hidden" name="id" value="@cfg.Id" />
                        <button type="submit" class="btn-danger btn" style="font-size:0.8rem; padding:0.3rem 0.7rem">Delete</button>
                    </form>
                </div>
            </div>

            @if (cfg.Config.Any())
            {
                <div class="text-sm text-muted" style="padding-top:0.25rem">
                    @if (cfg.Config.TryGetValue("channels", out var chs) && !string.IsNullOrEmpty(chs))
                    {
                        <span>Channels: @string.Join(", ", chs.Split(',').Select(s => "#" + s.Trim()))</span>
                    }
                    @if (cfg.Config.TryGetValue("notifyOn", out var no) && !string.IsNullOrEmpty(no))
                    {
                        <span class="ml-1">· Notify: @no</span>
                    }
                    @if (cfg.Config.TryGetValue("labelFilter", out var lf) && !string.IsNullOrEmpty(lf))
                    {
                        <span>Label: @lf</span>
                    }
                </div>
            }

            <div class="sync-status-bar" data-id="@cfg.Id" style="display:none"></div>
        </div>
    }
}

<style>
.sync-status-bar {
    margin-top: 0.5rem;
    padding: 0.35rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-family: monospace;
}
.sync-status-bar.syncing {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
}
.sync-status-bar.error {
    background: color-mix(in srgb, var(--danger) 12%, transparent);
    color: var(--danger);
}
.sync-status-bar.idle {
    color: var(--text-muted);
}
</style>

<script>
(function () {
    function fmtTime(iso) {
        if (!iso) return '';
        const d = new Date(iso);
        const now = new Date();
        const diff = Math.round((now - d) / 1000);
        if (diff < 60) return 'just now';
        if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
        return Math.floor(diff / 86400) + 'd ago';
    }

    async function poll() {
        try {
            const res = await fetch('/api/sync/status');
            if (!res.ok) return;
            const entries = await res.json();
            const map = {};
            for (const e of entries) map[e.instanceId] = e;

            document.querySelectorAll('.sync-status-bar').forEach(el => {
                const id = el.dataset.id;
                const e = map[id];

                el.style.display = '';

                if (!e) {
                    el.className = 'sync-status-bar idle';
                    el.textContent = '◌ Waiting for first sync…';
                    return;
                }

                el.className = 'sync-status-bar ' + (e.isSyncing ? 'syncing' : e.lastError ? 'error' : 'idle');

                if (e.isSyncing) {
                    el.textContent = '⟳ ' + (e.currentMessage || 'syncing…');
                } else if (e.lastError) {
                    el.textContent = '✕ ' + e.lastError;
                } else if (e.lastSyncAt) {
                    const items = e.itemsLastRun > 0 ? ` · ${e.itemsLastRun} item${e.itemsLastRun === 1 ? '' : 's'}` : '';
                    el.textContent = '✓ Last sync ' + fmtTime(e.lastSyncAt) + items;
                }
            });
        } catch {}
    }

    poll();
    setInterval(poll, 3000);
})();
</script>
