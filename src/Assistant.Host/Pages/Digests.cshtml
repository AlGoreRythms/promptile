@page
@model Assistant.Host.Pages.DigestsModel
@{
    ViewData["Title"] = "Digests";
}

<style>
.digest-list { list-style: none; margin: 0 0 1.5rem; padding: 0; }
.digest-item {
    padding: 0.4rem 0.6rem;
    border-radius: 5px;
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2px;
}
.digest-item:hover { background: var(--bg-card); color: var(--text); }
.digest-item.active { background: var(--accent-light); color: var(--accent); }
.md-content h1 { font-size: 1.15rem; margin: 0 0 0.5rem; }
.md-content h2 { font-size: 1rem; margin: 1.25rem 0 0.4rem; color: var(--text); }
.md-content p { margin: 0 0 0.6rem; font-size: 0.88rem; line-height: 1.6; }
.md-content ul, .md-content ol { margin: 0 0 0.6rem 1.25rem; font-size: 0.88rem; }
.md-content li { margin-bottom: 0.2rem; }
.md-content strong { color: var(--text); }
.md-content em { color: var(--text-muted); }
.md-content hr { border: none; border-top: 1px solid var(--border); margin: 1.25rem 0; }
</style>

<div class="brief-header">
    <h1 style="margin:0">Digests</h1>
</div>

@if (!Model.Digests.Any())
{
    <div class="card">
        <div style="color:var(--text-muted); font-size:0.9rem; padding:2rem 0; text-align:center">
            No digests yet — enable digest generation in Settings and one will be created at the configured hour.
        </div>
    </div>
}
else
{
    <div style="display:grid; grid-template-columns:180px 1fr; gap:1.5rem; align-items:start">
        <div>
            <div style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.4rem; text-transform:uppercase; letter-spacing:0.05em">Archives</div>
            <ul class="digest-list">
                @foreach (var (name, label) in Model.Digests)
                {
                    var active = name == Model.SelectedDigest;
                    <li class="digest-item @(active ? "active" : "")" onclick="window.location='/Digests?d=@name'">
                        @label
                    </li>
                }
            </ul>
        </div>
        <div class="card">
            @if (!string.IsNullOrEmpty(Model.SelectedContent))
            {
                <div class="md-content" data-markdown="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(Model.SelectedContent))"></div>
            }
        </div>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.md-content[data-markdown]').forEach(el => {
        el.innerHTML = marked.parse(el.dataset.markdown);
        el.removeAttribute('data-markdown');
    });
});
</script>
