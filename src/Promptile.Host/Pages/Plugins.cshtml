@page
@model Promptile.Host.Pages.PluginsModel
@{
    ViewData["Title"] = "Plugins";
}

<h1>Plugins</h1>
<p class="text-muted mb-2">Each plugin contributes pages, dashboard widgets, MCP tools, and background services.</p>

@if (!Model.PluginInfos.Any())
{
    <div class="card" style="text-align: center; padding: 3rem;">
        <h2>No plugins loaded</h2>
        <p class="text-muted mt-1">Add a plugin project reference to <code>Promptile.Host.csproj</code> and register it in <code>Program.cs</code>.</p>
    </div>
}
else
{
    @foreach (var info in Model.PluginInfos)
    {
        <div class="card mb-2 plugin-card @(!info.Enabled ? "plugin-disabled" : "")">
            <!-- Header -->
            <div class="plugin-card-header">
                <span class="plugin-card-icon">@info.Plugin.Icon</span>
                <div>
                    <h2 style="margin:0">@info.Plugin.DisplayName</h2>
                    <span class="text-sm text-muted">@info.Plugin.Id</span>
                </div>
                <div style="margin-left:auto; display:flex; align-items:center; gap:0.75rem;">
                    @if (info.Status != null && info.Enabled)
                    {
                        <span class="pill pill-neutral">@info.Status.Label</span>
                    }
                    <form method="post" style="margin:0">
                        <input type="hidden" name="pluginId" value="@info.Plugin.Id" />
                        <button type="submit" asp-page-handler="TogglePlugin"
                                class="toggle-btn @(info.Enabled ? "toggle-on" : "toggle-off")">
                            @(info.Enabled ? "Enabled" : "Disabled")
                        </button>
                    </form>
                </div>
            </div>

            @if (info.Enabled)
            {
                <!-- Summary bar: Pages, Widgets, Capabilities as inline tags -->
                <div class="plugin-summary">
                    <div class="plugin-summary-group">
                        <span class="plugin-summary-label">Pages</span>
                        @foreach (var nav in info.NavItems.OrderBy(n => n.Order))
                        {
                            <a href="@nav.Href" class="plugin-feature-tag">@nav.Label</a>
                        }
                    </div>
                    <div class="plugin-summary-group">
                        <span class="plugin-summary-label">Capabilities</span>
                        @if (info.IsCaptureTarget) { <span class="plugin-feature-tag">Capture</span> }
                        @if (info.Plugin is Promptile.Sdk.ITrayStatusProvider) { <span class="plugin-feature-tag">Tray Status</span> }
                        @{ var bgCount = info.Plugin.GetBackgroundServices().Count; }
                        @if (bgCount > 0) { <span class="plugin-feature-tag">@bgCount Bg Services</span> }
                        @if (info.Widgets.Any()) { <span class="plugin-feature-tag">@info.Widgets.Count Widget@(info.Widgets.Count != 1 ? "s" : "")</span> }
                    </div>
                </div>

                <!-- Two-column layout: MCP Tools | Tool Access -->
                @if (info.McpTools.Any() || info.AccessibleTools.Any())
                {
                    <div id="tools-columns-@info.Plugin.Id">
                        @await Html.PartialAsync("Shared/_PluginToolsColumns", info)
                    </div>
                }
            }
        </div>
    }
}

<script>
    // Hide fade gradient when scrolled to bottom
    document.querySelectorAll('.plugin-tools-scroll').forEach(function(el) {
        var wrap = el.closest('.plugin-tools-scroll-wrap');
        if (!wrap) return;

        function check() {
            var atBottom = el.scrollHeight - el.scrollTop - el.clientHeight < 4;
            var noScroll = el.scrollHeight <= el.clientHeight;
            wrap.classList.toggle('scrolled-bottom', atBottom || noScroll);
        }
        el.addEventListener('scroll', check);
        check();
    });
</script>
