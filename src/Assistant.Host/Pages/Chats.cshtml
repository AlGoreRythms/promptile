@page "/Chats"
@model Assistant.Host.Pages.ChatsModel
@{
    ViewData["Title"] = "Chats";
}

<style>
.chat-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    height: calc(100vh - 52px);
    margin: -2rem;
    overflow: hidden;
}
.chat-sidebar {
    background: var(--bg-card);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.chat-sidebar-header {
    padding: 0.75rem;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
}
.chat-sidebar-header button {
    width: 100%;
    font-size: 0.82rem;
    padding: 0.4rem 0.75rem;
}
.chat-sidebar-list {
    flex: 1;
    overflow-y: auto;
    padding: 0.4rem;
}
.conv-item {
    padding: 0.45rem 0.6rem;
    border-radius: 5px;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.25rem;
    margin-bottom: 1px;
}
.conv-item:hover { background: var(--bg); }
.conv-item.active { background: var(--accent-light); color: var(--accent); }
.conv-item-title { flex: 1; overflow: hidden; text-overflow: ellipsis; }
.conv-delete {
    opacity: 0; flex-shrink: 0; background: none; border: none;
    color: var(--text-muted); font-size: 0.75rem; padding: 0 2px;
    cursor: pointer; line-height: 1;
}
.conv-item:hover .conv-delete { opacity: 1; }
.conv-delete:hover { color: var(--danger); background: none; }
.chat-main {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
}
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}
.chat-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    gap: 1.25rem;
    text-align: center;
    padding: 3rem;
}
.chat-empty h2 { font-size: 1.1rem; color: var(--text-muted); margin: 0; }
.chat-suggestions { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
.chat-suggestion {
    padding: 0.4rem 0.9rem; border-radius: 999px; font-size: 0.8rem;
    border: 1px solid var(--border); background: var(--bg-card);
    color: var(--text-muted); cursor: pointer; transition: all 0.15s;
}
.chat-suggestion:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
.chat-msg { display: flex; flex-direction: column; max-width: 78%; }
.chat-msg-user { align-self: flex-end; align-items: flex-end; }
.chat-msg-assistant { align-self: flex-start; align-items: flex-start; }
.chat-bubble {
    padding: 0.6rem 1rem;
    border-radius: 12px;
    font-size: 0.9rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
}
.chat-msg-user .chat-bubble {
    background: var(--accent);
    color: #fff;
    border-radius: 12px 12px 4px 12px;
}
.chat-msg-assistant .chat-bubble {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px 12px 12px 4px;
    color: var(--text);
}
.chat-tool-calls {
    margin-top: 0.35rem;
    font-size: 0.75rem;
}
.chat-tool-calls summary {
    color: var(--text-muted);
    cursor: pointer;
    user-select: none;
    padding: 0.1rem 0;
    list-style: none;
}
.chat-tool-calls summary::before { content: "▸ "; }
.chat-tool-calls[open] summary::before { content: "▾ "; }
.chat-tool-call-item {
    padding: 0.35rem 0.6rem;
    margin-top: 0.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: monospace;
    color: var(--text-muted);
    font-size: 0.72rem;
}
.chat-tool-call-name { color: var(--accent); font-weight: 600; }
.chat-spinner .chat-bubble { color: var(--text-muted); }
.typing-dots span {
    display: inline-block;
    animation: typing-blink 1.2s infinite;
    font-size: 1.2rem;
    line-height: 0.5;
}
.typing-dots span:nth-child(2) { animation-delay: 0.2s; }
.typing-dots span:nth-child(3) { animation-delay: 0.4s; }
@@keyframes typing-blink { 0%, 80%, 100% { opacity: 0.2; } 40% { opacity: 1; } }
.chat-input-bar {
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--bg-card);
    display: flex;
    gap: 0.5rem;
    align-items: flex-end;
    flex-shrink: 0;
}
.chat-input-bar textarea {
    flex: 1;
    min-height: 40px;
    max-height: 120px;
    resize: none;
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    line-height: 1.5;
}
.chat-input-bar button {
    height: 40px;
    padding: 0 1.1rem;
    font-size: 0.85rem;
    border-radius: 8px;
    flex-shrink: 0;
}
.chat-input-bar button:disabled { opacity: 0.5; cursor: default; }
</style>

<div class="chat-layout">
    <!-- Sidebar -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <button class="secondary" onclick="newChat()">+ New Chat</button>
        </div>
        <div class="chat-sidebar-list" id="conv-list">
            @foreach (var conv in Model.RecentConversations)
            {
                <div class="conv-item" data-id="@conv.Id" onclick="loadConversation('@conv.Id')">
                    <span class="conv-item-title">@conv.Title</span>
                    <button class="conv-delete" onclick="deleteConversation(event,'@conv.Id')" title="Delete">✕</button>
                </div>
            }
        </div>
    </div>

    <!-- Chat pane -->
    <div class="chat-main">
        <div class="chat-messages" id="chat-messages">
            <div class="chat-empty" id="chat-empty">
                <h2>What can I help you with?</h2>
                <div class="chat-suggestions">
                    <button class="chat-suggestion" onclick="fillPrompt(this)">What emails did I get today?</button>
                    <button class="chat-suggestion" onclick="fillPrompt(this)">Summarize my recent Slack messages</button>
                    <button class="chat-suggestion" onclick="fillPrompt(this)">What data sources are connected?</button>
                    <button class="chat-suggestion" onclick="fillPrompt(this)">Any urgent emails I should know about?</button>
                </div>
            </div>
        </div>
        <div class="chat-input-bar">
            <textarea id="chat-input" placeholder="Ask anything…" rows="1"></textarea>
            <select id="agent-tier" title="Agent tier" style="height:40px; padding:0 0.5rem; font-size:0.8rem; border-radius:8px; flex-shrink:0; width:auto">
                <option value="light">Light</option>
                <option value="medium">Medium</option>
                <option value="heavy" selected>Heavy</option>
            </select>
            <button id="send-btn" onclick="sendMessage()">Send</button>
        </div>
        <div style="padding:0.3rem 1rem 0.4rem; border-top:1px solid var(--border); background:var(--bg-card); display:flex; align-items:center; gap:0.5rem; flex-shrink:0">
            <label style="display:flex; align-items:center; gap:0.35rem; font-size:0.75rem; color:var(--text-muted); cursor:pointer; user-select:none">
                <input type="checkbox" id="ctx-toggle" style="margin:0" />
                Set as 24h context (injects into all chat sessions)
            </label>
        </div>
    </div>
</div>

<script>
let currentConvId = null;

function setCurrentConv(id) {
    currentConvId = id;
    if (id) sessionStorage.setItem('chatConvId', id);
    else sessionStorage.removeItem('chatConvId');
}

function esc(str) {
    return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

function addMessage(role, content, toolCalls) {
    const container = document.getElementById('chat-messages');
    const empty = document.getElementById('chat-empty');
    if (empty) empty.remove();

    const div = document.createElement('div');
    div.className = `chat-msg chat-msg-${role}`;

    const bubble = document.createElement('div');
    bubble.className = 'chat-bubble';
    bubble.textContent = content;
    div.appendChild(bubble);

    if (toolCalls && toolCalls.length > 0) {
        const details = document.createElement('details');
        details.className = 'chat-tool-calls';
        const summary = document.createElement('summary');
        summary.textContent = `${toolCalls.length} tool call${toolCalls.length !== 1 ? 's' : ''}`;
        details.appendChild(summary);
        toolCalls.forEach(tc => {
            const item = document.createElement('div');
            item.className = 'chat-tool-call-item';
            item.innerHTML = `<span class="chat-tool-call-name">${esc(tc.name || tc.Name)}</span>`;
            details.appendChild(item);
        });
        div.appendChild(details);
    }

    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
    return div;
}

function addSpinner() {
    const container = document.getElementById('chat-messages');
    const div = document.createElement('div');
    div.className = 'chat-msg chat-msg-assistant chat-spinner';
    div.innerHTML = '<div class="chat-bubble"><span class="typing-dots"><span>·</span><span>·</span><span>·</span></span></div>';
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
    return div;
}

let _pollTimer = null;

async function sendMessage() {
    const input = document.getElementById('chat-input');
    const btn = document.getElementById('send-btn');
    const msg = input.value.trim();
    if (!msg || btn.disabled) return;

    const ctxToggle = document.getElementById('ctx-toggle');
    if (ctxToggle?.checked) {
        const form = new FormData();
        form.append('content', msg);
        await fetch('/api/context', { method: 'POST', body: form });
        ctxToggle.checked = false;
    }

    input.value = '';
    input.style.height = 'auto';
    input.disabled = true;
    btn.disabled = true;

    addMessage('user', msg, []);

    try {
        const agentTier = document.getElementById('agent-tier').value;
        const res = await fetch('/api/chat/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ conversationId: currentConvId, message: msg, agentTier }),
        });
        const data = await res.json();
        if (!res.ok) {
            addMessage('assistant', 'Error: ' + (data.error || res.statusText), []);
            input.disabled = false;
            btn.disabled = false;
            input.focus();
            return;
        }
        if (!currentConvId) {
            setCurrentConv(data.conversationId);
            prependSidebar(data.conversationId, msg);
        }
        startPolling(data.conversationId);
    } catch (e) {
        addMessage('assistant', 'Error: ' + e.message, []);
        input.disabled = false;
        btn.disabled = false;
        input.focus();
    }
}

function startPolling(convId) {
    stopPolling();
    const spinner = addSpinner();
    sessionStorage.setItem('chatPending', convId);

    _pollTimer = setInterval(async () => {
        try {
            const res = await fetch('/api/chat/poll/' + encodeURIComponent(convId));
            const data = await res.json();
            if (!data.pending) {
                stopPolling();
                sessionStorage.removeItem('chatPending');
                spinner.remove();
                if (data.reply) addMessage('assistant', data.reply, data.toolCalls || []);
                const input = document.getElementById('chat-input');
                const btn = document.getElementById('send-btn');
                input.disabled = false;
                btn.disabled = false;
                input.focus();
            }
        } catch (e) { /* keep polling */ }
    }, 2000);
}

function stopPolling() {
    if (_pollTimer) { clearInterval(_pollTimer); _pollTimer = null; }
}

function prependSidebar(id, firstMessage) {
    const list = document.getElementById('conv-list');
    const title = firstMessage.length > 50 ? firstMessage.substring(0, 50) + '…' : firstMessage;

    document.querySelectorAll('.conv-item').forEach(i => i.classList.remove('active'));

    const div = document.createElement('div');
    div.className = 'conv-item active';
    div.dataset.id = id;
    div.innerHTML = `<span class="conv-item-title">${esc(title)}</span>
        <button class="conv-delete" onclick="deleteConversation(event,'${id}')" title="Delete">✕</button>`;
    div.addEventListener('click', e => { if (!e.target.classList.contains('conv-delete')) loadConversation(id); });
    list.prepend(div);
}

function newChat() {
    setCurrentConv(null);
    const container = document.getElementById('chat-messages');
    container.innerHTML = `<div class="chat-empty" id="chat-empty">
        <h2>What can I help you with?</h2>
        <div class="chat-suggestions">
            <button class="chat-suggestion" onclick="fillPrompt(this)">What emails did I get today?</button>
            <button class="chat-suggestion" onclick="fillPrompt(this)">Summarize my recent Slack messages</button>
            <button class="chat-suggestion" onclick="fillPrompt(this)">What data sources are connected?</button>
            <button class="chat-suggestion" onclick="fillPrompt(this)">Any urgent emails I should know about?</button>
        </div>
    </div>`;
    document.querySelectorAll('.conv-item').forEach(i => i.classList.remove('active'));
    document.getElementById('chat-input').focus();
}

async function loadConversation(id) {
    document.querySelectorAll('.conv-item').forEach(i =>
        i.classList.toggle('active', i.dataset.id === id));

    try {
        const res = await fetch(`/api/chat/conversations/${id}`);
        const conv = await res.json();
        setCurrentConv(id);

        const container = document.getElementById('chat-messages');
        container.innerHTML = '';

        (conv.messages || []).forEach(msg =>
            addMessage(msg.role, msg.content, msg.toolCalls || []));
    } catch (e) {
        console.error('Failed to load conversation', e);
    }
}

async function deleteConversation(e, id) {
    e.stopPropagation();
    await fetch(`/api/chat/conversations/${id}`, { method: 'DELETE' });

    const item = document.querySelector(`.conv-item[data-id="${id}"]`);
    if (item) item.remove();

    if (currentConvId === id) { setCurrentConv(null); newChat(); }
}

function fillPrompt(btn) {
    const input = document.getElementById('chat-input');
    input.value = btn.textContent;
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
    input.focus();
}

document.addEventListener('DOMContentLoaded', async () => {
    const input = document.getElementById('chat-input');

    input.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    input.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 120) + 'px';
    });

    // Pre-load a conversation if linked from another page, or restore the last active one
    const params = new URLSearchParams(location.search);
    const conv = params.get('conv') || sessionStorage.getItem('chatConvId');
    const pending = sessionStorage.getItem('chatPending');
    if (conv) {
        await loadConversation(conv);
        if (pending === conv) startPolling(conv);
    } else {
        input.focus();
    }
});
</script>
