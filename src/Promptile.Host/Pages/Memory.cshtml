@page
@model Promptile.Host.Pages.MemoryModel
@{
    ViewData["Title"] = "Memory";
    var editing = Model.EditingPage;
    var viewing = Model.ViewingPage;
    var isNew = editing == "new";
    var cfg = Model.EditConfig;
}

<div class="flex justify-between items-center mb-2">
    <h1 style="margin:0">🧠 Memory</h1>
    @if (editing != null)
    {
        var cancelHref = (!isNew && editing != null) ? $"/Memory?view={Uri.EscapeDataString(editing)}" : "/Memory";
        <a href="@cancelHref" class="btn secondary">← Cancel</a>
    }
    else
    {
        <div class="flex gap-1">
            <form method="post" asp-page-handler="ScanAll" style="margin:0">
                <button type="submit" class="btn secondary">↺ Scan Now</button>
            </form>
            <a href="/Memory?edit=new" class="btn">+ Add Page</a>
        </div>
    }
</div>
<p class="text-muted mb-3" style="font-size:0.8rem">
    Scans every @Model.ScanIntervalMinutes min &middot; <a href="/Settings" style="color:var(--text-muted)">configure</a>
</p>

@if (editing != null)
{
    <div class="card" style="border-color:var(--accent)">
        <h2 style="margin-top:0">@(isNew ? "Add Memory Page" : $"Edit: {cfg?.Name ?? editing}")</h2>
        <form method="post" asp-page-handler="SavePage" id="save-page-form">
            <input type="hidden" name="oldName" value="@(cfg?.Name ?? "")" />

            <div class="mb-3">
                <label class="text-sm text-muted">Name</label>
                <input type="text" name="name" value="@(cfg?.Name ?? "")"
                       placeholder="e.g. people, weekly-news, decisions"
                       pattern="[a-zA-Z0-9_-]+" title="Letters, numbers, dashes and underscores only"
                       required style="max-width:300px" />
            </div>

            <div class="mb-3">
                <label class="text-sm text-muted">Description <span class="text-muted">(optional)</span></label>
                <input type="text" name="description" value="@(cfg?.Description ?? "")"
                       placeholder="What this page tracks" style="max-width:400px" />
            </div>

            <div style="display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:1rem">
                <div>
                    <label class="text-sm text-muted">Mode</label>
                    <select name="mode" style="width:auto">
                        @foreach (var m in new[] { "rolling", "daily", "weekly", "monthly" })
                        {
                            var sel = (cfg?.Mode ?? "rolling") == m ? "selected" : null;
                            <option value="@m" selected="@sel">@m</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="text-sm text-muted">Agent tier</label>
                    <select name="agentTier" style="width:auto">
                        @foreach (var tier in new[] { "light", "medium", "heavy" })
                        {
                            var sel = (cfg?.AgentTier ?? "light") == tier ? "selected" : null;
                            <option value="@tier" selected="@sel">@tier</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="text-sm text-muted">Retention <span class="text-muted">(dated only)</span></label>
                    <div style="display:flex;align-items:center;gap:0.5rem">
                        <input type="number" name="retentionPeriods" value="@(cfg?.RetentionPeriods?.ToString() ?? "")"
                               placeholder="keep all" min="1" style="max-width:100px" />
                        <span class="text-muted" style="font-size:0.8rem">periods (blank = keep all)</span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="text-sm text-muted">Sources to scan <span class="text-muted">(blank = all sources)</span></label>
                <input type="hidden" name="scanSources" id="scan-sources-hidden" />
                <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.3rem" id="scan-sources-picker"></div>
            </div>

            <div class="mb-3">
                <label class="text-sm text-muted">Prompt</label>
                <p class="text-sm text-muted mt-1 mb-1">
                    System prompt for the agent. The user turn will include the current page content and a chunk of new source data.
                </p>
                <textarea name="prompt" rows="10" required
                          style="width:100%; font-size:0.85rem; font-family:monospace; resize:vertical"
                          placeholder="You maintain a memory page about key people. Extract names, roles, and notable facts from the data. Write concisely. Merge with existing content — do not repeat what is already recorded.">@(cfg?.Prompt ?? "")</textarea>
            </div>

        </form>
        <div class="flex gap-2" style="margin-top:1rem">
            <button type="submit" form="save-page-form">Save</button>
            @{
                var cancelHref2 = (!isNew && editing != null) ? $"/Memory?view={Uri.EscapeDataString(editing)}" : "/Memory";
            }
            <a href="@cancelHref2" class="btn secondary">Cancel</a>
            @if (!isNew && cfg != null)
            {
                <form method="post" asp-page-handler="DeletePage" style="margin:0">
                    <input type="hidden" name="name" value="@cfg.Name" />
                    <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Delete page \'@(cfg.Name)\' and its content?')">Delete</button>
                </form>
            }
        </div>
    </div>
}
else if (!Model.Pages.Any())
{
    <div class="card" style="text-align:center; padding:3rem">
        <h2>No memory pages yet</h2>
        <p class="text-muted mt-1 mb-3">
            Add a page to define what memory should track.
            Each page has its own prompt, mode, and source selection.
        </p>
        <a href="/Memory?edit=new" class="btn">+ Add Page</a>
    </div>
}
else
{
    var vcfg = Model.ViewConfig;
    <div style="display:grid; grid-template-columns:240px 1fr; gap:1rem; height:calc(100vh - 11rem); min-height:400px">

        @* ── Left panel: page stubs ── *@
        <div class="card" style="overflow-y:auto; padding:0; display:flex; flex-direction:column">
            @foreach (var pg in Model.Pages)
            {
                var isActive = string.Equals(pg.Name, viewing, StringComparison.OrdinalIgnoreCase);
                var preview = Model.PagePreviews.GetValueOrDefault(pg.Name);
                <a href="/Memory?view=@Uri.EscapeDataString(pg.Name)"
                   style="display:block; padding:0.6rem 0.75rem; text-decoration:none; border-bottom:1px solid var(--border);
                          background:@(isActive ? "var(--accent)" : "transparent");
                          color:@(isActive ? "#fff" : "var(--text)")">
                    <div style="display:flex; align-items:baseline; gap:0.4rem; flex-wrap:wrap">
                        <strong style="font-size:0.9rem">@pg.Name</strong>
                        <span style="padding:0.1rem 0.4rem; border-radius:4px; font-size:0.68rem;
                                     background:@(isActive ? "rgba(255,255,255,0.2)" : "var(--surface-2,#f0f0f0)");
                                     color:@(isActive ? "rgba(255,255,255,0.85)" : "var(--text-muted)")">@pg.Mode</span>
                        <span style="padding:0.1rem 0.4rem; border-radius:4px; font-size:0.68rem;
                                     background:@(isActive ? "rgba(255,255,255,0.2)" : "var(--surface-2,#f0f0f0)");
                                     color:@(isActive ? "rgba(255,255,255,0.85)" : "var(--text-muted)")">@pg.AgentTier</span>
                    </div>
                    @if (!string.IsNullOrEmpty(pg.Description))
                    {
                        <div style="font-size:0.78rem; margin-top:0.15rem;
                                    color:@(isActive ? "rgba(255,255,255,0.75)" : "var(--text-muted)");
                                    white-space:nowrap; overflow:hidden; text-overflow:ellipsis">
                            @pg.Description
                        </div>
                    }
                    @if (preview == null)
                    {
                        <div style="font-size:0.72rem; margin-top:0.15rem; font-style:italic;
                                    color:@(isActive ? "rgba(255,255,255,0.55)" : "var(--text-muted)")">no content yet</div>
                    }
                </a>
            }
        </div>

        @* ── Right panel: selected page content ── *@
        <div style="overflow-y:auto; display:flex; flex-direction:column; gap:0.75rem">
            @if (viewing == null || vcfg == null)
            {
                <div class="card" style="flex:1; display:flex; align-items:center; justify-content:center">
                    <p class="text-muted">Select a page on the left to view its content.</p>
                </div>
            }
            else
            {
                @* Page header *@
                <div class="flex justify-between items-center" style="flex-shrink:0">
                    <div style="display:flex; align-items:baseline; gap:0.5rem; flex-wrap:wrap">
                        <strong style="font-size:1.1rem">@vcfg.Name</strong>
                        <span style="padding:0.15rem 0.5rem; border-radius:4px; font-size:0.72rem;
                                     background:var(--surface-2,#f0f0f0); color:var(--text-muted)">@vcfg.Mode</span>
                        <span style="padding:0.15rem 0.5rem; border-radius:4px; font-size:0.72rem;
                                     background:var(--surface-2,#f0f0f0); color:var(--text-muted)">@vcfg.AgentTier</span>
                        @if (!string.IsNullOrEmpty(vcfg.Description))
                        {
                            <span class="text-muted" style="font-size:0.875rem">— @vcfg.Description</span>
                        }
                    </div>
                    <div class="flex gap-1" style="flex-shrink:0">
                        <button type="button" class="btn secondary" style="font-size:0.8rem; padding:0.25rem 0.6rem"
                                onclick="showMemoryConfig()" title="View config">⊞</button>
                        <a href="/Memory?edit=@Uri.EscapeDataString(vcfg.Name)"
                           class="btn secondary" style="font-size:0.8rem; padding:0.25rem 0.6rem">Edit</a>
                        <form method="post" asp-page-handler="RefreshPage" style="margin:0">
                            <input type="hidden" name="name" value="@vcfg.Name" />
                            <button type="submit" class="btn secondary" style="font-size:0.8rem; padding:0.25rem 0.6rem">↺ Refresh</button>
                        </form>
                        @if (vcfg.Mode != "rolling" && Model.ViewLabel != null)
                        {
                            <form method="post" asp-page-handler="DeleteSnapshot" style="margin:0">
                                <input type="hidden" name="name" value="@vcfg.Name" />
                                <input type="hidden" name="label" value="@Model.ViewLabel" />
                                <button type="submit" class="btn btn-danger" style="font-size:0.8rem; padding:0.25rem 0.6rem"
                                        onclick="return confirm('Delete this snapshot?')">Delete</button>
                            </form>
                        }
                    </div>
                </div>

                @if (vcfg.Mode == "rolling")
                {
                    <div class="card" style="flex:1">
                        @if (Model.ViewContent != null)
                        {
                            <div class="md-content" data-markdown="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(Model.ViewContent))"
                                 style="font-size:0.9rem"></div>
                        }
                        else
                        {
                            <p class="text-muted">No content yet — will be filled on next scan or Refresh.</p>
                        }
                    </div>
                }
                else
                {
                    @* Dated page: snapshot pill row + content *@
                    @if (Model.ViewSnapshots.Any())
                    {
                        <div style="display:flex; flex-wrap:wrap; gap:0.3rem; flex-shrink:0">
                            @foreach (var (snapLabel, _) in Model.ViewSnapshots)
                            {
                                var isActivSnap = snapLabel == Model.ViewLabel;
                                <a href="/Memory?view=@Uri.EscapeDataString(vcfg.Name)&label=@Uri.EscapeDataString(snapLabel)"
                                   title="@snapLabel"
                                   style="display:inline-block; padding:0.2rem 0.55rem; border-radius:4px; font-size:0.8rem;
                                          text-decoration:none;
                                          background:@(isActivSnap ? "var(--accent)" : "var(--surface-2,#f0f0f0)");
                                          color:@(isActivSnap ? "#fff" : "var(--text-muted)")">
                                    @MemoryModel.FormatLabel(snapLabel)
                                </a>
                            }
                        </div>
                    }
                    <div class="card" style="flex:1">
                        @if (Model.ViewContent != null)
                        {
                            @if (Model.ViewLabel != null)
                            {
                                <p class="text-muted mb-2" style="font-size:0.8rem" title="@Model.ViewLabel">@MemoryModel.FormatLabel(Model.ViewLabel)</p>
                            }
                            <div class="md-content" data-markdown="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(Model.ViewContent))"
                                 style="font-size:0.9rem"></div>
                        }
                        else
                        {
                            <p class="text-muted">No content yet — will be filled on next scan or Refresh.</p>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @if (viewing != null && vcfg != null)
    {
        var cfgJson = System.Text.Json.JsonSerializer.Serialize(new {
            name        = vcfg.Name,
            mode        = vcfg.Mode,
            agentTier   = vcfg.AgentTier,
            retention   = vcfg.RetentionPeriods.HasValue ? $"Keep last {vcfg.RetentionPeriods} periods" : "Keep all",
            scanSources = vcfg.ScanSources.Count > 0 ? string.Join(", ", vcfg.ScanSources) : "(all sources)",
            prompt      = vcfg.Prompt,
            viewLabel   = Model.ViewLabel,  // null for rolling, current snapshot label for dated
        });
        <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
        <script>
            marked.use({ breaks: true, gfm: true });
            document.querySelectorAll('.md-content[data-markdown]').forEach(el => {
                el.innerHTML = marked.parse(el.dataset.markdown);
                el.removeAttribute('data-markdown');
            });

            const _memoryCfg = @Html.Raw(cfgJson);

            function showMemoryConfig() {
                const cfg = _memoryCfg;
                const tabStyle = (active) =>
                    `cursor:pointer;padding:.4rem .9rem;font-size:.85rem;font-weight:500;border:none;` +
                    `background:none;border-bottom:2px solid ${active?'var(--accent)':'transparent'};` +
                    `color:${active?'var(--text)':'var(--text-muted)'};margin-bottom:-1px`;

                const overlay = document.createElement('div');
                overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;display:flex;align-items:center;justify-content:center';
                overlay.innerHTML = `
                    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;width:90vw;max-width:900px;height:85vh;display:flex;flex-direction:column;overflow:hidden">
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:.6rem 1rem;border-bottom:1px solid var(--border);flex-shrink:0">
                            <div style="display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:-1px;padding-bottom:0">
                                <button id="mcfg-tab-source" style="${tabStyle(true)}"  onclick="mcfgTab('source')">Source Data</button>
                                <button id="mcfg-tab-prompt" style="${tabStyle(false)}" onclick="mcfgTab('prompt')">Prompt</button>
                                <button id="mcfg-tab-config" style="${tabStyle(false)}" onclick="mcfgTab('config')">Config</button>
                            </div>
                            <button onclick="this.closest('[style*=fixed]').remove()" style="background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--text-muted);margin-left:1rem">✕</button>
                        </div>
                        <div id="mcfg-body" style="flex:1;overflow:auto;padding:1rem;font-size:0.85rem"></div>
                    </div>`;

                overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
                document.body.appendChild(overlay);

                const promptHtml = marked.parse(`## Prompt\n\n\`\`\`\n${cfg.prompt}\n\`\`\``);
                const configHtml = marked.parse(
                    `## Config\n\n| | |\n|---|---|\n` +
                    `| **Mode** | ${cfg.mode} |\n` +
                    `| **Agent tier** | ${cfg.agentTier} |\n` +
                    `| **Retention** | ${cfg.retention} |\n` +
                    `| **Scan sources** | ${cfg.scanSources} |`
                );

                window._mcfgCache = {};
                window.mcfgTab = async (tab) => {
                    ['source','prompt','config'].forEach(t => {
                        const btn = document.getElementById('mcfg-tab-' + t);
                        if (btn) btn.style.cssText = tabStyle(t === tab);
                    });
                    const body = document.getElementById('mcfg-body');
                    if (tab === 'prompt') { body.innerHTML = promptHtml; return; }
                    if (tab === 'config') { body.innerHTML = configHtml; return; }

                    // Source data — fetch lazily, cache result
                    if (window._mcfgCache.source) { body.innerHTML = window._mcfgCache.source; return; }
                    body.innerHTML = '<p style="color:var(--text-muted)">Loading source data…</p>';
                    const url = `/Memory?handler=Source&name=${encodeURIComponent(cfg.name)}` +
                                (cfg.viewLabel ? `&label=${encodeURIComponent(cfg.viewLabel)}` : '');
                    try {
                        const res = await fetch(url);
                        const text = await res.text();
                        const pre = `<pre style="white-space:pre-wrap;font-size:0.8rem;margin:0">${text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</pre>`;
                        window._mcfgCache.source = pre;
                        body.innerHTML = pre;
                    } catch (e) {
                        body.innerHTML = `<p style="color:var(--danger)">Failed to load source data.</p>`;
                    }
                };
                window.mcfgTab('source');

                document.addEventListener('keydown', function escMcfg(e) {
                    if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', escMcfg); }
                });
            }
        </script>
    }
}

@if (editing != null)
{
    var availSources = System.Text.Json.JsonSerializer.Serialize(Model.AvailableSources);
    var availTypes   = System.Text.Json.JsonSerializer.Serialize(Model.AvailableSourceTypes);
    var selSources   = System.Text.Json.JsonSerializer.Serialize(Model.EditConfig?.ScanSources ?? []);
    <script>
    (function () {
        const availableSources     = @Html.Raw(availSources);
        const availableSourceTypes = @Html.Raw(availTypes);
        const selectedSources      = @Html.Raw(selSources);

        function esc(s) {
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function updateSrcMaskBtn(wrap) {
            const name  = wrap.dataset.name;
            const allCb = wrap.querySelector('.src-mask-all');
            const types = [...wrap.querySelectorAll('.src-mask-type:checked')].map(t => t.value);
            const active = allCb.checked || types.length > 0;
            const btn = wrap.querySelector('.src-mask-btn');
            btn.classList.toggle('active', active);
            btn.textContent = active ? (allCb.checked ? name : `${name}: ${types.join(', ')}`) : name;
        }

        function toggleSrcMask(btn) {
            const dd   = btn.nextElementSibling;
            const open = dd.style.display !== 'none';
            document.querySelectorAll('.src-mask-dropdown').forEach(d => d.style.display = 'none');
            if (!open) dd.style.display = 'block';
        }

        document.addEventListener('click', e => {
            if (!e.target.closest('.src-mask-wrap'))
                document.querySelectorAll('.src-mask-dropdown').forEach(d => d.style.display = 'none');
        });

        function buildPicker() {
            const picker = document.getElementById('scan-sources-picker');
            if (!picker) return;

            picker.innerHTML = availableSources.map(name => {
                const types    = availableSourceTypes[name] || [];
                const selAll   = selectedSources.includes(name);
                const selTypes = selectedSources.filter(e => e.startsWith(name+':')).map(e => e.slice(name.length+1));
                const active   = selAll || selTypes.length > 0;
                const label    = active ? (selAll ? name : `${name}: ${selTypes.join(', ')}`) : name;

                return `<div class="src-mask-wrap" data-name="${esc(name)}" style="position:relative">
                    <button type="button" class="src-mask-btn ${active?'active':''}"
                            onclick="toggleSrcMask(this)">${esc(label)}</button>
                    <div class="src-mask-dropdown" style="display:none;position:absolute;top:100%;left:0;z-index:200;
                         background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:0.4rem 0;
                         min-width:150px;margin-top:2px;box-shadow:0 4px 12px rgba(0,0,0,.2)">
                        <label class="src-mask-item" style="display:flex;align-items:center;gap:0.4rem;padding:0.25rem 0.75rem;
                               cursor:pointer;font-size:0.85rem;border-bottom:1px solid var(--border);margin-bottom:0.2rem">
                            <input type="checkbox" class="src-mask-all" ${selAll?'checked':''}
                                   onchange="srcMaskAllChanged(this)"> All
                        </label>
                        ${types.map(t => `
                        <label class="src-mask-item" style="display:flex;align-items:center;gap:0.4rem;
                               padding:0.25rem 0.75rem;cursor:pointer;font-size:0.85rem">
                            <input type="checkbox" class="src-mask-type" value="${esc(t)}"
                                   ${selAll||selTypes.includes(t)?'checked':''}
                                   ${selAll?'disabled':''}
                                   onchange="srcMaskTypeChanged(this)"> ${esc(t)}
                        </label>`).join('')}
                    </div>
                </div>`;
            }).join('');
        }

        function srcMaskAllChanged(cb) {
            const wrap = cb.closest('.src-mask-wrap');
            wrap.querySelectorAll('.src-mask-type').forEach(t => { t.checked = cb.checked; t.disabled = cb.checked; });
            updateSrcMaskBtn(wrap);
        }

        function srcMaskTypeChanged(cb) { updateSrcMaskBtn(cb.closest('.src-mask-wrap')); }

        function collectSrcMask() {
            const result = [];
            document.querySelectorAll('#scan-sources-picker .src-mask-wrap').forEach(wrap => {
                const name  = wrap.dataset.name;
                const allCb = wrap.querySelector('.src-mask-all');
                if (allCb?.checked) { result.push(name); return; }
                wrap.querySelectorAll('.src-mask-type:checked').forEach(t => result.push(`${name}:${t.value}`));
            });
            return result;
        }

        document.querySelector('form[action*="SavePage"], form').addEventListener('submit', function () {
            const hidden = document.getElementById('scan-sources-hidden');
            if (hidden) hidden.value = collectSrcMask().join(', ');
        });

        buildPicker();

        window.toggleSrcMask      = toggleSrcMask;
        window.srcMaskAllChanged  = srcMaskAllChanged;
        window.srcMaskTypeChanged = srcMaskTypeChanged;
    })();
    </script>
}
