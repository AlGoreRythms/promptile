@inject PluginRegistry PluginRegistry
@inject Assistant.Host.Services.SettingsService SettingsService
@{
    var requestPath = ViewContext.HttpContext.Request.Path.ToString();
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
    var _hiddenNames = SettingsService.LoadSync().HiddenNames;
    var _isSecurityPage = requestPath.StartsWith("/Settings", StringComparison.OrdinalIgnoreCase)
        && ViewContext.HttpContext.Request.Query["tab"].ToString() == "security";

    var navByPlugin = PluginRegistry.NavItemsByPlugin;
    (Assistant.Sdk.IPlugin Plugin, List<Assistant.Sdk.NavItem> Items)? activePluginGroup = null;
    foreach (var group in navByPlugin)
    {
        if (group.Items.Any(n => requestPath.StartsWith(n.Href, StringComparison.OrdinalIgnoreCase)))
        {
            activePluginGroup = group;
            break;
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Assistant - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function() {
            var t = localStorage.getItem('tray-theme') || 'light';
            if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        })();
    </script>
</head>
<body>
    <nav>
        <a class="logo" href="/">ASSISTANT</a>
        <a href="/" class="@(currentPage == "/Index" ? "active" : "")">Dashboard</a>
        <a href="/Chats" class="@(currentPage == "/Chats" ? "active" : "")">Chats</a>
        <a href="/Work" class="@(currentPage == "/Work" ? "active" : "")">Work</a>
        <a href="/Memory" class="@(currentPage == "/Memory" ? "active" : "")">Memory</a>
        @if (navByPlugin.Any())
        {
            <span class="nav-separator"></span>
            <div id="plugin-tabs" class="nav-plugin-tabs">
                @foreach (var group in navByPlugin)
                {
                    var isActive = activePluginGroup?.Plugin == group.Plugin;
                    var firstHref = group.Items.OrderBy(n => n.Order).First().Href;
                    <div class="nav-plugin @(isActive ? "active" : "")" data-plugin-id="@group.Plugin.Id" data-href="@firstHref">
                        <span class="nav-plugin-icon">@group.Plugin.Icon</span>
                        @group.Plugin.DisplayName
                    </div>
                }
            </div>
        }
        <a href="/Settings" class="@(currentPage == "/Settings" ? "active" : "")" style="margin-left:auto">Settings</a>
    </nav>
    @if (activePluginGroup != null)
    {
        <nav class="subnav">
            @foreach (var item in activePluginGroup.Value.Items.OrderBy(n => n.Order))
            {
                <a href="@item.Href" class="@(requestPath.Equals(item.Href, StringComparison.OrdinalIgnoreCase) ? "active" : "")">@item.Label</a>
            }
        </nav>
    }
    <main>
        @RenderBody()
    </main>
    <script src="~/js/htmx.min.js"></script>
    <script src="~/js/sortable.min.js"></script>
    <script>
        document.addEventListener('htmx:configRequest', function(evt) {
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                evt.detail.headers['RequestVerificationToken'] = token.value;
            }
        });

        // Draggable plugin tabs
        (function() {
            var tabs = document.getElementById('plugin-tabs');
            if (!tabs) return;
            var didDrag = false;
            new Sortable(tabs, {
                animation: 150,
                ghostClass: 'nav-plugin-ghost',
                draggable: '.nav-plugin',
                onStart: function() { didDrag = true; },
                onEnd: function() {
                    var order = Array.from(tabs.querySelectorAll('[data-plugin-id]'))
                        .map(function(el) { return el.dataset.pluginId; });
                    var form = new FormData();
                    form.append('order', order.join(','));
                    fetch('/api/plugin-order', { method: 'POST', body: form });
                    setTimeout(function() { didDrag = false; }, 50);
                }
            });
            // Click to navigate (but not after a drag)
            tabs.addEventListener('click', function(e) {
                if (didDrag) return;
                var tab = e.target.closest('.nav-plugin');
                if (tab && tab.dataset.href) window.location.href = tab.dataset.href;
            });
        })();

        @if (_hiddenNames.Count > 0 && !_isSecurityPage)
        {
            <text>
        (function() {
            var hidden = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                _hiddenNames.Select(n => n.ToLowerInvariant()).ToList()));

            function matchesHidden(text) {
                var t = (text || '').trim().toLowerCase();
                return hidden.some(function(n) { return t === n || t.startsWith(n + ' ') || t.startsWith(n + '\n'); });
            }

            document.addEventListener('DOMContentLoaded', function() {
                // Nav plugin tabs
                document.querySelectorAll('.nav-plugin').forEach(function(el) {
                    if (matchesHidden(el.textContent)) el.style.display = 'none';
                });

                // Cards — check first strong, h2, or direct title element
                document.querySelectorAll('.card, .widget-card').forEach(function(el) {
                    var title = el.querySelector('strong, h2, .widget-title, .plugin-card-header strong');
                    if (title && matchesHidden(title.textContent)) {
                        var item = el.closest('.grid-stack-item') || el;
                        item.style.display = 'none';
                    }
                });

                // Table rows — check first td
                document.querySelectorAll('tr').forEach(function(el) {
                    var cell = el.querySelector('td');
                    if (cell && matchesHidden(cell.textContent)) el.style.display = 'none';
                });


            });
        })();
            </text>
        }
    </script>
</body>
</html>
